<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- App Group so the extension and the main app can share the pending link.
     The SAME group id must be enabled on the main app target too. -->
<plist version="1.0">
<dict>
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.YOURNAME.fitcheck</string>
    </array>
</dict>
</plist>
